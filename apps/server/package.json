{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs",
		"regen-doc": "bun scripts/regen-doc.ts"
	},
	"dependencies": {
		"@ai-sdk/google": "^1.2.12",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@virusmore/api": "workspace:*",
		"@virusmore/db": "workspace:*",
		"drizzle-orm": "^0.45.1",
		"@virusmore/env": "workspace:*",
		"ai": "^4.3.16",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@virusmore/config": "workspace:*",
		"tsdown": "^0.16.5",
		"typescript": "catalog:"
	}
}
