---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";

const examples = [
  {
    type: "file",
    id: "3ecc0186adba60fb53e9f6c494623dcea979a95c3e66a52896693b8d22f5e18b",
    label: "WannaCry ransomware (Trojan.Ransom.WannaCryptor)",
    threat: "malicious",
  },
  {
    type: "domain",
    id: "malware.wicar.org",
    label: "malware.wicar.org",
    threat: "malicious",
  },
  {
    type: "ip-address",
    id: "1.1.1.1",
    label: "1.1.1.1 — Cloudflare DNS",
    threat: "clean",
  },
];

const threatStyle: Record<string, string> = {
  malicious: "color: var(--threat-malicious); background: color-mix(in srgb, var(--threat-malicious) 10%, transparent); border-color: color-mix(in srgb, var(--threat-malicious) 25%, transparent);",
  suspicious: "color: var(--threat-suspicious); background: color-mix(in srgb, var(--threat-suspicious) 10%, transparent); border-color: color-mix(in srgb, var(--threat-suspicious) 25%, transparent);",
  clean: "color: var(--threat-clean); background: color-mix(in srgb, var(--threat-clean) 10%, transparent); border-color: color-mix(in srgb, var(--threat-clean) 25%, transparent);",
};
---

<Layout title="VirusMore — AI-powered security analysis">
  <div class="h-screen overflow-hidden flex flex-col">

    <!-- Header -->
    <header class="h-14 border-b border-border bg-background/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-5xl mx-auto h-full px-6 flex items-center justify-between">
        <div class="flex items-center gap-2.5 text-foreground">
          <Logo size={32} class="text-primary" />
          <span class="font-semibold tracking-tight text-[0.95rem]">VirusMore</span>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://www.virustotal.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            VirusTotal
          </a>
          <button
            id="theme-toggle"
            class="h-8 w-8 rounded-md border border-border flex items-center justify-center text-muted-foreground hover:bg-secondary hover:text-foreground transition-colors"
            aria-label="Toggle color theme"
          >
            <svg id="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg id="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <main class="flex-1 flex flex-col items-center justify-center px-6 relative overflow-hidden">

      <!-- Gradient orbs -->
      <div class="orb w-[600px] h-[400px] top-[-80px] left-1/2 -translate-x-1/2" style="background: radial-gradient(ellipse, rgba(129,140,248,0.18) 0%, transparent 70%);"></div>
      <div class="orb w-[350px] h-[350px] top-[10%] left-[10%]" style="background: radial-gradient(ellipse, rgba(6,182,212,0.12) 0%, transparent 70%);"></div>
      <div class="orb w-[300px] h-[300px] top-[15%] right-[8%]" style="background: radial-gradient(ellipse, rgba(52,211,153,0.10) 0%, transparent 70%);"></div>

      <div class="w-full max-w-[760px] text-center space-y-7 relative z-10">

        <!-- Browser chrome + URL bar demo -->
        <div class="browser-chrome">
          <!-- Traffic lights + nav -->
          <div class="browser-chrome-left">
            <span class="traffic-dot" style="background:#ff5f57;"></span>
            <span class="traffic-dot" style="background:#ffbd2e;"></span>
            <span class="traffic-dot" style="background:#28c940;"></span>
            <div class="nav-btns">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
          </div>
          <!-- URL bar -->
          <div class="url-demo-bar">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="url-demo-lock">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span class="url-demo-protocol">https://</span><span id="url-host" class="url-demo-host">virustotal</span><span id="url-cursor" class="url-demo-cursor"></span><span class="url-demo-rest">.com/gui/file/<span class="url-demo-hash">3ecc0186adba60fb53e9f6…e18b</span></span>
          </div>
          <!-- Spacer to balance left side -->
          <div class="browser-chrome-right"></div>
        </div>

        <!-- Headline -->
        <div class="space-y-2">
          <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.08]">
            Threat intel,
          </h1>
          <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.08] gradient-text">
            explained by AI.
          </h1>
        </div>

        <!-- Subtext -->
        <p class="text-muted-foreground text-lg leading-relaxed max-w-[480px] mx-auto">
          Replace <code class="rounded px-1.5 py-0.5 text-[0.82em] font-mono" style="background: var(--secondary); border: 1px solid var(--border); color: var(--foreground);">virustotal.com</code> with
          <code class="rounded px-1.5 py-0.5 text-[0.82em] font-mono" style="background: color-mix(in srgb, var(--primary) 10%, transparent); border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent); color: var(--primary);">virusmore.com</code>
          in any VirusTotal URL to get AI documentation and an interactive analysis agent.
        </p>

        <!-- Search -->
        <form id="search-form" class="flex gap-2 mt-2">
          <div class="flex-1 relative">
            <div class="absolute inset-0 rounded-xl pointer-events-none" style="background: linear-gradient(135deg, rgba(129,140,248,0.15), rgba(6,182,212,0.08)); padding: 1px;">
            </div>
            <input
              id="search-input"
              type="text"
              placeholder="Paste a VirusTotal URL, SHA256 hash, domain or IP..."
              autocomplete="off"
              spellcheck="false"
              class="w-full h-11 rounded-xl px-4 text-sm text-foreground placeholder:text-muted-foreground outline-none font-mono relative z-10 transition-all"
              style="background: var(--secondary); border: 1px solid var(--border);"
            />
          </div>
          <button
            type="submit"
            class="h-11 px-5 rounded-xl text-sm font-semibold shrink-0 flex items-center gap-2 transition-all hover:opacity-90"
            style="background: var(--primary); color: var(--primary-foreground);"
          >
            Analyze
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </form>

        <p class="text-xs text-muted-foreground">Supports files (SHA256/MD5), URLs, domains, and IP addresses.</p>
      </div>

      <!-- Examples -->
      <div class="w-full max-w-[780px] mt-10 relative z-10">
        <p class="text-[0.62rem] font-semibold uppercase tracking-widest text-muted-foreground mb-3 px-1">
          Quick examples
        </p>
        <div class="grid grid-cols-3 gap-3">
          {examples.map((ex) => (
            <a
              href={`/gui/${ex.type}/${ex.id}`}
              class="group flex flex-col gap-2.5 p-4 rounded-2xl no-underline transition-all hover:scale-[1.02] min-w-0"
              style="background: var(--card); border: 1px solid var(--border);"
            >
              <div class="flex items-center justify-between">
                <span class="text-[0.58rem] font-bold border rounded px-1.5 py-0.5 uppercase tracking-wider shrink-0" style={threatStyle[ex.threat]}>
                  {ex.threat}
                </span>
                <span class="text-[0.62rem] text-muted-foreground capitalize">
                  {ex.type === "ip-address" ? "IP" : ex.type}
                </span>
              </div>
              <span class="text-xs text-foreground font-mono truncate block">
                {ex.label}
              </span>
              <div class="flex justify-end mt-auto">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground group-hover:text-foreground group-hover:translate-x-0.5 transition-all" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Powered by -->
      <div class="flex flex-col items-center gap-3 mt-12 relative z-10 opacity-60">
        <span class="text-[0.6rem] font-semibold uppercase tracking-widest text-muted-foreground">Powered by</span>
        <div class="flex items-center gap-8">
          <img src="/virustotal.png" alt="VirusTotal" class="h-9 w-auto" style="filter: brightness(0) invert(0.4);" />
          <img src="/gemini.png"     alt="Gemini"     class="h-9 w-auto" style="filter: brightness(0) invert(0.4);" />
        </div>
      </div>
    </main>

    <footer class="border-t border-border py-4 shrink-0">
      <p class="text-center text-[0.68rem] text-muted-foreground/40">
        VirusMore is not affiliated with VirusTotal or Google LLC.
      </p>
    </footer>
  </div>

  <!-- Animated mouse cursor (fixed, pointer-events none) -->
  <div id="demo-mouse" style="position:fixed;pointer-events:none;z-index:9999;opacity:0;">

    <!-- macOS arrow cursor — black fill, white rounded border -->
    <svg id="demo-mouse-arrow" width="28" height="32" viewBox="0 0 28 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M4 2 L4 24 L9 18.5 L13 27.5 L16.5 26 L12.5 17 L21 17 Z"
        fill="#0d0d0d"
        stroke="white"
        stroke-width="3"
        stroke-linejoin="round"
        stroke-linecap="round"
        paint-order="stroke fill"
      />
    </svg>

    <!-- macOS I-beam — narrow arcs, stem doesn't touch arcs (hotspot = 5,13) -->
    <svg id="demo-mouse-ibeam" width="7" height="18" viewBox="0 0 10 26" fill="none" style="display:none;" xmlns="http://www.w3.org/2000/svg">
      <!-- white border (painted first) — stem uses butt so it doesn't bleed past the bars -->
      <line x1="5" y1="5"  x2="5" y2="21" stroke="white"   stroke-width="2.8" stroke-linecap="butt"/>
      <line x1="2" y1="5"  x2="8" y2="5"  stroke="white"   stroke-width="3"   stroke-linecap="square"/>
      <line x1="2" y1="21" x2="8" y2="21" stroke="white"   stroke-width="3"   stroke-linecap="square"/>
      <!-- black on top -->
      <line x1="5" y1="5"  x2="5" y2="21" stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="butt"/>
      <line x1="2" y1="5"  x2="8" y2="5"  stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="square"/>
      <line x1="2" y1="21" x2="8" y2="21" stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="square"/>
    </svg>

  </div>
</Layout>


<style>
  /* ── Browser chrome wrapper ───────────────────────────────────────────── */
  .browser-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 18px;
    border-radius: 9999px;
    border: 1.5px solid var(--border);
    background: var(--card);
    box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.10);
  }

  .browser-chrome-left {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .browser-chrome-right {
    flex-shrink: 0;
    width: 4px;
  }

  .traffic-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: block;
    flex-shrink: 0;
  }

  .nav-btns {
    display: flex;
    gap: 2px;
    color: var(--muted-foreground);
    opacity: 0.35;
  }

  /* ── URL demo bar ─────────────────────────────────────────────────────── */
  .url-demo-bar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 6px 12px;
    border-radius: 7px;
    border: 1.5px solid var(--border);
    background: var(--secondary);
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 12.5px;
    white-space: nowrap;
    overflow: hidden;
    transition: border-color 0.4s, box-shadow 0.4s;
  }

  /* focused state toggled by JS */
  .url-demo-bar.focused {
    border-color: color-mix(in srgb, var(--primary) 60%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent);
  }

  .url-demo-lock {
    flex-shrink: 0;
    margin-right: 7px;
    color: var(--threat-clean);
    opacity: 0.7;
    transition: color 0.5s;
  }

  .url-demo-protocol { color: var(--muted-foreground); opacity: 0.6; }

  .url-demo-host {
    color: var(--foreground);
    font-weight: 600;
    transition: color 0.4s;
  }

  /* "virusmore" state */
  .url-demo-host.vm {
    color: var(--primary);
  }

  .url-demo-cursor {
    display: inline-block;
    width: 1.5px;
    height: 13px;
    background: var(--primary);
    vertical-align: middle;
    margin: 0 0.5px;
    opacity: 0;
    border-radius: 1px;
    flex-shrink: 0;
  }

  .url-demo-cursor.active {
    animation: url-cursor-blink 0.65s steps(1) infinite;
  }

  .url-demo-rest { color: var(--muted-foreground); opacity: 0.55; }

  .url-demo-hash { opacity: 0.7; }

  /* lock turns primary when on virusmore */
  .url-demo-bar.vm .url-demo-lock { color: var(--primary); opacity: 0.8; }

  @keyframes url-cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @keyframes demo-mouse-click {
    0%   { transform: scale(1);    }
    35%  { transform: scale(0.72); }
    100% { transform: scale(1);    }
  }
  #demo-mouse.clicking {
    animation: demo-mouse-click 0.18s ease-out forwards;
  }
</style>


<script>
  /* ── Theme toggle ─────────────────────────────────────────────────────── */
  const btn  = document.getElementById("theme-toggle");
  const moon = document.getElementById("icon-moon");
  const sun  = document.getElementById("icon-sun");

  function syncIcons() {
    const dark = document.documentElement.classList.contains("dark");
    moon?.classList.toggle("hidden", dark);
    sun?.classList.toggle("hidden", !dark);
  }
  syncIcons();

  btn?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
    syncIcons();
  });

  /* ── Search form ──────────────────────────────────────────────────────── */
  document.getElementById("search-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const raw = (document.getElementById("search-input") as HTMLInputElement).value.trim();
    if (!raw) return;

    const vtMatch = raw.match(/virustotal\.com\/gui\/(file|url|domain|ip-address)\/([^/?#]+)/);
    if (vtMatch) { window.location.href = `/gui/${vtMatch[1]}/${vtMatch[2]}`; return; }

    if (/^[a-fA-F0-9]{64}$/.test(raw)) { window.location.href = `/gui/file/${raw.toLowerCase()}`; return; }
    if (/^[a-fA-F0-9]{32}$/.test(raw)) { window.location.href = `/gui/file/${raw.toLowerCase()}`; return; }
    if (/^\d{1,3}(\.\d{1,3}){3}$/.test(raw)) { window.location.href = `/gui/ip-address/${raw}`; return; }
    if (/^[a-zA-Z0-9][a-zA-Z0-9-]{0,61}[a-zA-Z0-9]?\.[a-zA-Z]{2,}/.test(raw)) { window.location.href = `/gui/domain/${raw}`; return; }

    alert("Input not recognized. Paste a VirusTotal URL or a valid SHA256 hash.");
  });

  /* ── Input glow ───────────────────────────────────────────────────────── */
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  input?.addEventListener("focus", () => {
    input.style.borderColor = "var(--ring)";
    input.style.boxShadow = "0 0 0 3px color-mix(in srgb, var(--ring) 20%, transparent)";
  });
  input?.addEventListener("blur", () => {
    input.style.borderColor = "var(--border)";
    input.style.boxShadow = "none";
  });

  /* ── Card hover glow ──────────────────────────────────────────────────── */
  document.querySelectorAll<HTMLAnchorElement>("a[href^='/gui/']").forEach((card) => {
    card.addEventListener("mouseenter", () => {
      card.style.borderColor = "color-mix(in srgb, var(--primary) 40%, transparent)";
      card.style.background = "color-mix(in srgb, var(--primary) 4%, var(--card))";
    });
    card.addEventListener("mouseleave", () => {
      card.style.borderColor = "var(--border)";
      card.style.background = "var(--card)";
    });
  });

  /* ── URL bar animation loop ───────────────────────────────────────────── */
  const bar      = document.querySelector(".url-demo-bar")    as HTMLElement;
  const hostEl   = document.getElementById("url-host")        as HTMLSpanElement;
  const cursorEl = document.getElementById("url-cursor")      as HTMLSpanElement;
  const mouseEl    = document.getElementById("demo-mouse")       as HTMLElement;
  const arrowSvg   = document.getElementById("demo-mouse-arrow") as HTMLElement;
  const ibeamSvg   = document.getElementById("demo-mouse-ibeam") as HTMLElement;

  function sleep(ms: number) {
    return new Promise<void>((r) => setTimeout(r, ms));
  }

  async function runUrlDemo() {
    while (true) {
      /* ── Reset ── */
      mouseEl.style.transition = "none";
      mouseEl.style.opacity    = "0";
      mouseEl.classList.remove("clicking");
      arrowSvg.style.display = "";
      ibeamSvg.style.display = "none";
      hostEl.textContent = "virustotal";
      hostEl.classList.remove("vm");
      bar.classList.remove("focused", "vm");
      cursorEl.classList.remove("active");
      cursorEl.style.opacity = "0";

      await sleep(1800);

      /* ── Place cursor (arrow) off to the bottom-right of the click target ── */
      const rect   = hostEl.getBoundingClientRect();
      // arrow: tip at (4, 2) in 28×32 SVG
      const arrowX = rect.right - 4;
      const arrowY = rect.top + rect.height / 2 - 2;
      // i-beam: hotspot at center (3.5, 9) in 7×18 rendered
      const ibeamX = rect.right - 3.5;
      const ibeamY = rect.top + rect.height / 2 - 9;

      arrowSvg.style.display = "";
      ibeamSvg.style.display = "none";

      // Instant reposition (no transition) — force reflow so browser commits it
      mouseEl.style.transition = "none";
      mouseEl.style.left    = `${arrowX + 65}px`;
      mouseEl.style.top     = `${arrowY + 55}px`;
      mouseEl.style.opacity = "0";
      void mouseEl.getBoundingClientRect(); // force reflow

      /* ── Glide arrow toward target ── */
      mouseEl.style.transition = "left 0.52s cubic-bezier(0.22,1,0.36,1), top 0.52s cubic-bezier(0.22,1,0.36,1), opacity 0.2s";
      mouseEl.style.opacity = "1";
      mouseEl.style.left = `${arrowX}px`;
      mouseEl.style.top  = `${arrowY}px`;

      await sleep(280); // midway — swap to I-beam

      arrowSvg.style.display = "none";
      ibeamSvg.style.display = "";
      // Instant hotspot adjust + finish glide
      mouseEl.style.transition = "left 0.26s cubic-bezier(0.22,1,0.36,1), top 0.26s cubic-bezier(0.22,1,0.36,1)";
      mouseEl.style.left = `${ibeamX}px`;
      mouseEl.style.top  = `${ibeamY}px`;

      await sleep(290);

      /* ── Click ── */
      mouseEl.classList.add("clicking");
      bar.classList.add("focused");

      await sleep(190);
      mouseEl.classList.remove("clicking");

      await sleep(120);

      /* ── Mouse fades out, text cursor appears ── */
      mouseEl.style.transition = "opacity 0.25s";
      mouseEl.style.opacity    = "0";

      cursorEl.style.opacity = "1";
      cursorEl.classList.add("active");

      await sleep(320);

      /* ── Delete "virustotal" ── */
      let text = "virustotal";
      while (text.length > 0) {
        text = text.slice(0, -1);
        hostEl.textContent = text;
        await sleep(82);
      }

      await sleep(160);

      /* ── Type "virusmore" ── */
      const target = "virusmore";
      for (const ch of target) {
        text += ch;
        hostEl.textContent = text;
        await sleep(112);
      }

      await sleep(300);

      /* ── "Enter": cursor off, host turns primary ── */
      cursorEl.classList.remove("active");
      cursorEl.style.opacity = "0";
      hostEl.classList.add("vm");
      bar.classList.remove("focused");
      bar.classList.add("vm");

      await sleep(3000);
    }
  }

  runUrlDemo();
</script>
