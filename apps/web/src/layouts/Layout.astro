---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = "VirusMore — AI-powered security analysis",
  description = "Replace virustotal.com with virusmore.com in any VirusTotal URL to get AI-generated documentation and an interactive analysis agent.",
  ogTitle,
  ogDescription,
} = Astro.props;

const siteUrl = "https://virusmore.com";
const ogImage = `${siteUrl}/virusmore.png`;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090f" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={siteUrl} />
    <meta property="og:title"       content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:width"  content="3408" />
    <meta property="og:image:height" content="1778" />
    <meta property="og:site_name"   content="VirusMore" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image"       content={ogImage} />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <slot />
    <script>
      const stored = localStorage.getItem("theme");
      if (stored === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    </script>
  </body>
</html>
